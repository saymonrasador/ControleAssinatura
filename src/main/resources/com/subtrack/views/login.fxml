<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane styleClass="auth-container" xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.subtrack.controller.LoginController"
           prefWidth="900" prefHeight="600">

    <VBox styleClass="auth-card" spacing="20" alignment="CENTER">
        <Label text="SubTrack" styleClass="label-title"/>
        <Label text="Entre para gerenciar suas assinaturas" styleClass="label-subtitle"/>

        <VBox spacing="4">
            <Label text="Email *" styleClass="label-muted"/>
            <TextField fx:id="emailField" promptText="Digite seu email"/>
        </VBox>

        <VBox spacing="4">
            <Label text="Senha *" styleClass="label-muted"/>
            <PasswordField fx:id="passwordField" promptText="Digite sua senha"/>
        </VBox>

        <Label fx:id="errorLabel" styleClass="label-error" wrapText="true"/>

        <Button text="Entrar" onAction="#handleLogin" maxWidth="Infinity"/>

        <HBox alignment="CENTER" spacing="6">
            <Label text="Não tem uma conta?" styleClass="label-muted"/>
            <Hyperlink text="Registrar-se" onAction="#handleRegisterLink"/>
        </HBox>
    </VBox>
</StackPane>
